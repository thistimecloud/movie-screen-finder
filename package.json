{
  "name": "movie-screen-finder",
  "version": "1.0.0",
  "description": "映画名で検索し、東京の映画館をスクリーンサイズ順に上映情報を表示",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "node server/index.js",
    "build": "vite build"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  }
}
